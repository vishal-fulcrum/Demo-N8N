{"id":"aLD2HKMTLgRQWM7U","name":"Notifications - Meeting Reminder - Slack","nodes":[{"name":"Daily 12 PM Check","type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.3,"parameters":{"rule":{"interval":[{"field":"days","daysInterval":1,"triggerAtHour":12,"triggerAtMinute":0}]}}},{"name":"Get Todays Events","type":"n8n-nodes-base.googleCalendar","typeVersion":1.3,"parameters":{"resource":"event","operation":"getAll","calendar":{"__rl":true,"mode":"id","value":"primary"},"returnAll":false,"limit":50,"timeMin":"={{ $now.toISO() }}","timeMax":"={{ $now.endOf('day').toISO() }}","options":{"singleEvents":true,"orderBy":"startTime"}}},{"name":"Has Meetings Today?","type":"n8n-nodes-base.if","typeVersion":2.2,"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"loose"},"conditions":[{"leftValue":"={{ $json.summary }}","operator":{"type":"string","operation":"isNotEmpty"}}],"combinator":"and"}}},{"name":"Filter Events In Next 60 Min","type":"n8n-nodes-base.code","typeVersion":2,"parameters":{"language":"javaScript","jsCode":"const results = [];\nconst now = new Date();\n\nfor (const item of $input.all()) {\n  const event = item.json;\n  if (!event.start || !event.start.dateTime) continue;\n\n  const startTime = new Date(event.start.dateTime);\n  const minutesUntilStart = (startTime - now) / (1000 * 60);\n\n  if (minutesUntilStart >= 13 && minutesUntilStart <= 60) {\n    results.push({\n      json: {\n        summary: event.summary || 'Meeting',\n        startTime: event.start.dateTime,\n        endTime: event.end ? event.end.dateTime : null,\n        htmlLink: event.htmlLink || '',\n        minutesUntilStart: Math.round(minutesUntilStart),\n        formattedStart: startTime.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true })\n      }\n    });\n  }\n}\n\nreturn results;"}},{"name":"Has Upcoming Meetings?","type":"n8n-nodes-base.if","typeVersion":2.2,"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"loose"},"conditions":[{"leftValue":"={{ $json.summary }}","operator":{"type":"string","operation":"isNotEmpty"}}],"combinator":"and"}}},{"name":"Send Meeting Reminder","type":"n8n-nodes-base.slack","typeVersion":2.4,"parameters":{"resource":"message","operation":"post","authentication":"oAuth2","select":"user","user":{"__rl":true,"mode":"id","value":"me"},"messageType":"text","text":"={{ '\ud83d\uddd3\ufe0f *Meeting Reminder* \u2014 Starting in ~' + $json.minutesUntilStart + ' minutes\\n\\n*' + $json.summary + '*\\n\u23f0 ' + $json.formattedStart + (($json.htmlLink && $json.htmlLink !== '') ? '\\n\ud83d\udd17 <' + $json.htmlLink + '|Join Meeting>' : '') }}","otherOptions":{"mrkdwn":true,"includeLinkToWorkflow":false}}},{"name":"No Events Today","type":"n8n-nodes-base.noOp","typeVersion":1,"parameters":{}}]}